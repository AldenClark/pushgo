    "sound_folder_permission_explanation" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PushGo benötigt Lese- und Schreibzugriff auf ~/Library/Sounds, bevor eigene Benachrichtigungstöne gespeichert werden können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
