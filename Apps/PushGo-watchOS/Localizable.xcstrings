    "system_notification_permission_is_not_obtained_please_turn_on_notifications_in_the_system_settings_and_try_again" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have turned off notification permission, so PushGo cannot alert you about new messages, events, or object updates. Open Settings to enable notifications, then return to continue."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通知がオフのため、新着メッセージ・イベント・オブジェクト更新をPushGoが知らせられません。設定で通知をオンにしてから、この画面に戻ってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "알림이 꺼져 있어 새 메시지, 이벤트, 객체 업데이트를 PushGo가 알려줄 수 없습니다. 설정에서 알림을 켠 뒤 이 화면으로 돌아와 주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们发现你已关闭 PushGo 通知，可能会错过新的消息、事件和对象更新。去系统设置打开通知后，回来就能第一时间收到提醒。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我們發現你已關閉 PushGo 通知，可能會錯過新的訊息、事件和物件更新。到系統設定開啟通知後，回來就能第一時間收到提醒。"
          }
        }
      }
    },
