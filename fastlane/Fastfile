default_platform(:ios)

require "fileutils"
require "find"
require "json"
require "pathname"
require "shellwords"
require "tempfile"
require "tmpdir"

platform :ios do
  def repo_root
    File.expand_path("..", __dir__)
  end

  def resolve_from_repo(path)
    return path if path.to_s.empty?
    return path if Pathname.new(path).absolute?

    File.expand_path(path, repo_root)
  end

  def app_store_api_key!
    key_id = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]
    key_content = ENV["ASC_KEY_P8"]

    UI.user_error!("Missing ASC_KEY_ID") if key_id.to_s.empty?
    UI.user_error!("Missing ASC_ISSUER_ID") if issuer_id.to_s.empty?
    UI.user_error!("Missing ASC_KEY_P8") if key_content.to_s.empty?

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      is_key_content_base64: ENV.fetch("ASC_KEY_IS_BASE64", "false") == "true"
    )
  end

  def local_signing_xcargs(signing_identity: nil)
    parts = []
    team_id = ENV["APPLE_TEAM_ID"].to_s.strip

    display_version = resolved_display_version
    unless display_version.empty?
      parts << "PUSHGO_DISPLAY_VERSION=#{Shellwords.escape(display_version)}"
    end

    parts << "DEVELOPMENT_TEAM=#{team_id}" unless team_id.empty?
    keychain_path = release_signing_keychain_path!
    parts << "OTHER_CODE_SIGN_FLAGS=#{Shellwords.escape("--keychain #{keychain_path}")}"
    unless signing_identity.to_s.empty?
      parts << "CODE_SIGN_IDENTITY=#{Shellwords.escape(signing_identity)}"
    end

    parts.join(" ")
  end

  def unsigned_archive_xcargs
    parts = []
    display_version = resolved_display_version
    unless display_version.empty?
      parts << "PUSHGO_DISPLAY_VERSION=#{Shellwords.escape(display_version)}"
    end
    parts << "CODE_SIGNING_ALLOWED=NO"
    parts << "CODE_SIGNING_REQUIRED=NO"
    parts << "CODE_SIGN_IDENTITY=''"
    parts << "DEVELOPMENT_TEAM=''"
    parts.join(" ")
  end

  def export_archive_xcargs
    parts = []
    keychain_path = release_signing_keychain_path!
    parts << "OTHER_CODE_SIGN_FLAGS=#{Shellwords.escape("--keychain #{keychain_path}")}"
    parts.join(" ")
  end

  def resolved_display_version
    display_version = ENV["PUSHGO_DISPLAY_VERSION"].to_s.strip
    return display_version unless display_version.empty?

    semver_full_version = ENV["SEMVER_FULL_VERSION"].to_s.strip
    return "" if semver_full_version.empty?

    semver_full_version.start_with?("v", "V") ? semver_full_version : "v#{semver_full_version}"
  end

  def ensure_team_id!
    team_id = ENV["APPLE_TEAM_ID"].to_s.strip
    UI.user_error!("Missing APPLE_TEAM_ID") if team_id.empty?
    team_id
  end

  def verify_ios_distribution_signature!(ipa_path)
    scratch_dir = Dir.mktmpdir("pushgo-ios-signature-")
    begin
      sh("ditto -x -k #{Shellwords.escape(ipa_path)} #{Shellwords.escape(scratch_dir)}")
      app_path = Dir.glob(File.join(scratch_dir, "Payload", "*.app")).first
      UI.user_error!("No .app found inside IPA payload at #{ipa_path}") if app_path.to_s.empty?
      output = sh("codesign -d --verbose=4 #{Shellwords.escape(app_path)} 2>&1", log: false)
      unless output.include?("Authority=Apple Distribution")
        UI.user_error!("iOS IPA is not signed with Apple Distribution.\n#{output}")
      end

      verify_expected_entitlements!(
        artifact_label: "iOS IPA",
        actual_entitlements_by_bundle_id: extracted_entitlements_by_bundle_id(app_path),
        expected_entitlements_by_bundle_id: expected_store_entitlements_by_bundle_id(ios_store_entitlements_sources)
      )
    ensure
      FileUtils.rm_rf(scratch_dir)
    end
  end

  def verify_macos_pkg_distribution_signature!(pkg_path)
    output = sh("pkgutil --check-signature #{Shellwords.escape(pkg_path)} 2>&1", log: false)
    unless output.include?("Mac Installer Distribution") || output.include?("3rd Party Mac Developer Installer")
      UI.user_error!("macOS pkg is not signed with a Mac Installer Distribution certificate.\n#{output}")
    end

    scratch_root = Dir.mktmpdir("pushgo-macos-pkg-")
    expanded_pkg_dir = File.join(scratch_root, "expanded")
    begin
      # pkgutil expects a destination path that does not already exist.
      sh("pkgutil --expand-full #{Shellwords.escape(pkg_path)} #{Shellwords.escape(expanded_pkg_dir)}")
      app_path = Dir.glob(File.join(expanded_pkg_dir, "**", "*.app")).find do |candidate|
        bundle_identifier_for(candidate) == "io.ethan.pushgo"
      end
      UI.user_error!("No PushGo.app found inside pkg payload at #{pkg_path}") if app_path.to_s.empty?

      verify_expected_entitlements!(
        artifact_label: "macOS pkg",
        actual_entitlements_by_bundle_id: extracted_entitlements_by_bundle_id(app_path),
        expected_entitlements_by_bundle_id: expected_store_entitlements_by_bundle_id(macos_store_entitlements_sources)
      )
    ensure
      FileUtils.rm_rf(scratch_root)
    end
  end

  def verify_developer_id_app_signature!(app_path)
    output = sh("codesign -d --verbose=4 #{Shellwords.escape(app_path)} 2>&1", log: false)
    return if output.include?("Authority=Developer ID Application")

    UI.user_error!("DMG app is not signed with Developer ID Application.\n#{output}")
  end

  def developer_id_keychain_path!
    keychain_path = ENV["DEVELOPER_ID_KEYCHAIN_PATH"].to_s.strip
    UI.user_error!("Missing DEVELOPER_ID_KEYCHAIN_PATH") if keychain_path.empty?
    keychain_path
  end

  def release_signing_keychain_path!
    keychain_path = ENV["RELEASE_SIGNING_KEYCHAIN_PATH"].to_s.strip
    UI.user_error!("Missing RELEASE_SIGNING_KEYCHAIN_PATH") if keychain_path.empty?
    keychain_path
  end

  def matching_keychain_identities(keychain_path:, labels:, policy: "codesigning")
    output = sh(
      "security find-identity -v -p #{Shellwords.escape(policy)} #{Shellwords.escape(keychain_path)}",
      log: false
    )

    output.lines.filter_map do |line|
      next unless line =~ /\s*\d+\)\s+([0-9A-F]{40})\s+"([^"]+)"/

      sha = Regexp.last_match(1)
      name = Regexp.last_match(2)
      next unless labels.any? { |label| name.include?(label) }

      {
        sha: sha,
        name: name
      }
    end
  end

  def require_code_signing_identity!(labels:, configured_identity_env: nil, keychain_path:, policy: "codesigning")
    configured_identity = configured_identity_env.to_s.strip
    identities = matching_keychain_identities(keychain_path: keychain_path, labels: labels, policy: policy)
    UI.user_error!("No signing identity found in #{keychain_path} for #{labels.join(' / ')}") if identities.empty?
    return identities.first if configured_identity.empty?

    matched_identity = identities.find do |identity|
      identity[:sha] == configured_identity || identity[:name] == configured_identity
    end
    if matched_identity.nil?
      UI.user_error!("Configured signing identity not found: #{configured_identity} (expected one of #{labels.join(', ')})")
    end

    matched_identity
  end

  def apple_distribution_identity!
    require_code_signing_identity!(
      labels: ["Apple Distribution"],
      configured_identity_env: ENV["APPLE_DISTRIBUTION_IDENTITY"],
      keychain_path: release_signing_keychain_path!
    )
  end

  def mac_installer_distribution_identity!
    require_code_signing_identity!(
      labels: ["Mac Installer Distribution", "3rd Party Mac Developer Installer"],
      configured_identity_env: ENV["MAC_INSTALLER_DISTRIBUTION_IDENTITY"],
      keychain_path: release_signing_keychain_path!,
      policy: "basic"
    )
  end

  def developer_id_identity!
    keychain_path = developer_id_keychain_path!
    configured_identity = ENV["DEVELOPER_ID_APPLICATION_IDENTITY"].to_s.strip
    require_code_signing_identity!(
      labels: ["Developer ID Application"],
      configured_identity_env: configured_identity,
      keychain_path: keychain_path
    )[:sha]
  end

  def developer_id_entitlements_sources
    {
      "io.ethan.pushgo" => resolve_from_repo("Apps/PushGo-macOS/pushgomac.entitlements"),
      "io.ethan.pushgo.NotificationServiceExtension" => resolve_from_repo("Extensions/PushGoNSE-macOS/PushgoNotificationServiceExtension.entitlements")
    }
  end

  def developer_id_provisioning_profiles
    {
      "io.ethan.pushgo" => env_value!("DEVELOPER_ID_PROFILE_MACOS_APP_UUID"),
      "io.ethan.pushgo.NotificationServiceExtension" => env_value!("DEVELOPER_ID_PROFILE_MACOS_NSE_UUID")
    }
  end

  def developer_id_signing_targets
    {
      "io.ethan.pushgo" => ENV.fetch("APP_MACOS_DMG_SCHEME", ENV.fetch("APP_MACOS_SCHEME", "PushGo-macOS-DMG")),
      "io.ethan.pushgo.NotificationServiceExtension" => "PushGoNSE-macOS"
    }
  end

  def plist_hash(path)
    JSON.parse(sh("plutil -convert json -o - #{Shellwords.escape(path)}", log: false))
  end

  def write_plist_hash(path, payload)
    json_path = "#{path}.json"
    File.write(json_path, JSON.pretty_generate(payload))
    sh("plutil -convert xml1 -o #{Shellwords.escape(path)} #{Shellwords.escape(json_path)}")
  ensure
    FileUtils.rm_f(json_path) if defined?(json_path)
  end

  def deep_copy_hash(payload)
    JSON.parse(JSON.generate(payload))
  end

  def extracted_entitlements_hash(path)
    raw_plist = sh("codesign -d --entitlements :- #{Shellwords.escape(path)} 2>/dev/null", log: false)
    return nil if raw_plist.to_s.strip.empty?

    Tempfile.create(["pushgo-entitlements", ".plist"]) do |tempfile|
      tempfile.write(raw_plist)
      tempfile.flush
      return plist_hash(tempfile.path)
    end
  rescue StandardError
    nil
  end

  def extracted_entitlements_by_bundle_id(root_bundle_path)
    entitlements_by_bundle_id = {}

    ([root_bundle_path] + all_nested_code_bundles(root_bundle_path)).each do |bundle_path|
      bundle_id = bundle_identifier_for(bundle_path)
      next if bundle_id.to_s.empty?

      entitlements = extracted_entitlements_hash(bundle_path)
      next if entitlements.nil?

      entitlements_by_bundle_id[bundle_id] = entitlements
    end

    entitlements_by_bundle_id
  end

  def all_nested_code_bundles(path)
    bundles = []

    Find.find(path) do |candidate|
      next if candidate == path
      next unless File.directory?(candidate)
      next unless %w[.app .appex .framework .xpc].include?(File.extname(candidate))

      bundles << candidate
    end

    bundles.sort_by { |bundle_path| bundle_path.count(File::SEPARATOR) }.reverse
  end

  def normalized_entitlements_hash(entitlements)
    normalized = deep_copy_hash(entitlements)

    application_identifier = normalized["application-identifier"] || normalized["com.apple.application-identifier"]
    unless application_identifier.nil?
      normalized["application-identifier"] = application_identifier
      normalized["com.apple.application-identifier"] = application_identifier
    end

    aps_environment = normalized["aps-environment"] || normalized["com.apple.developer.aps-environment"]
    unless aps_environment.nil?
      normalized["aps-environment"] = aps_environment
      normalized["com.apple.developer.aps-environment"] = aps_environment
    end

    normalized
  end

  def ios_store_entitlements_sources
    {
      "io.ethan.pushgo" => resolve_from_repo("Apps/PushGo-iOS/pushgo.entitlements"),
      "io.ethan.pushgo.NotificationServiceExtension" => resolve_from_repo("Extensions/PushGoNSE-iOS/NotificationServiceExtension.entitlements"),
      "io.ethan.pushgo.watchkitapp" => resolve_from_repo("Apps/PushGo-watchOS/pushgowatch Watch App.entitlements"),
      "io.ethan.pushgo.watchkitapp.NotificationServiceExtension" => resolve_from_repo("Extensions/PushGoNSE-watchOS/pushgowatch NotificationServiceExtension.entitlements")
    }
  end

  def macos_store_entitlements_sources
    {
      "io.ethan.pushgo" => resolve_from_repo("Apps/PushGo-macOS/pushgomac.entitlements"),
      "io.ethan.pushgo.NotificationServiceExtension" => resolve_from_repo("Extensions/PushGoNSE-macOS/PushgoNotificationServiceExtension.entitlements")
    }
  end

  def sanitized_store_entitlements_for(bundle_id, entitlements_sources)
    source_path = entitlements_sources[bundle_id]
    return nil if source_path.to_s.empty?

    entitlements = normalized_entitlements_hash(plist_hash(source_path))
    team_id = ensure_team_id!
    application_identifier = "#{team_id}.#{bundle_id}"

    entitlements.delete("com.apple.security.get-task-allow")
    entitlements.delete("get-task-allow")
    entitlements["application-identifier"] = application_identifier
    entitlements["com.apple.application-identifier"] = application_identifier
    entitlements["com.apple.developer.team-identifier"] = team_id

    if entitlements.key?("aps-environment") || entitlements.key?("com.apple.developer.aps-environment")
      entitlements["aps-environment"] = "production"
      entitlements["com.apple.developer.aps-environment"] = "production"
    end

    if entitlements["keychain-access-groups"].is_a?(Array)
      entitlements["keychain-access-groups"] =
        entitlements["keychain-access-groups"].map do |group|
          group.gsub(/\A[A-Z0-9]+\./, "#{team_id}.").gsub("$(AppIdentifierPrefix)", "#{team_id}.")
        end
    end

    normalized_entitlements_hash(entitlements)
  end

  def expected_store_entitlements_by_bundle_id(entitlements_sources)
    entitlements_sources.each_with_object({}) do |(bundle_id, _), result|
      entitlements = sanitized_store_entitlements_for(bundle_id, entitlements_sources)
      next if entitlements.nil?

      result[bundle_id] = entitlements
    end
  end

  def verify_expected_entitlements!(artifact_label:, actual_entitlements_by_bundle_id:, expected_entitlements_by_bundle_id:)
    actual = actual_entitlements_by_bundle_id.transform_values { |entitlements| normalized_entitlements_hash(entitlements) }
    errors = []

    expected_entitlements_by_bundle_id.each do |bundle_id, expected_entitlements|
      actual_entitlements = actual[bundle_id]
      if actual_entitlements.nil?
        errors << "#{bundle_id}: missing signed bundle entitlements"
        next
      end

      expected_entitlements.each do |key, expected_value|
        actual_value = actual_entitlements[key]
        next if actual_value == expected_value

        errors << "#{bundle_id}: entitlement #{key} expected #{expected_value.inspect}, got #{actual_value.inspect}"
      end
    end

    return if errors.empty?

    UI.user_error!(
      "#{artifact_label} is missing required signed entitlements:\n" \
      "#{errors.first(20).join("\n")}"
    )
  end

  def build_settings_for_target(target_name)
    @build_settings_for_target ||= {}
    return @build_settings_for_target[target_name] if @build_settings_for_target.key?(target_name)

    project = resolve_from_repo(ENV.fetch("APP_PROJECT", "pushgo.xcodeproj"))
    output = sh(
      "xcodebuild -project #{Shellwords.escape(project)} " \
      "-target #{Shellwords.escape(target_name)} " \
      "-showBuildSettings",
      log: false
    )

    settings = {}
    output.each_line do |line|
      next unless line =~ /^\s*([A-Z0-9_]+)\s=\s(.*)$/

      settings[Regexp.last_match(1)] = Regexp.last_match(2).strip
    end

    @build_settings_for_target[target_name] = settings
  end

  def bundle_identifier_for(path)
    info_plist_path = [File.join(path, "Info.plist"), File.join(path, "Contents", "Info.plist")].find do |candidate|
      File.exist?(candidate)
    end
    return nil if info_plist_path.nil?

    sh(
      "/usr/libexec/PlistBuddy -c 'Print :CFBundleIdentifier' #{Shellwords.escape(info_plist_path)}",
      log: false
    ).strip
  rescue
    nil
  end

  def bundle_executable_path(path)
    info_plist_path = [File.join(path, "Info.plist"), File.join(path, "Contents", "Info.plist")].find do |candidate|
      File.exist?(candidate)
    end
    return nil if info_plist_path.nil?

    executable_name = sh(
      "/usr/libexec/PlistBuddy -c 'Print :CFBundleExecutable' #{Shellwords.escape(info_plist_path)}",
      log: false
    ).strip
    return nil if executable_name.empty?

    macos_executable_path = File.join(path, "Contents", "MacOS", executable_name)
    return macos_executable_path if File.exist?(macos_executable_path)

    direct_executable_path = File.join(path, executable_name)
    return direct_executable_path if File.exist?(direct_executable_path)

    nil
  rescue
    nil
  end

  def apply_xcode_managed_entitlements!(bundle_id, entitlements)
    target_name = developer_id_signing_targets[bundle_id]
    return if target_name.to_s.empty?

    build_settings = build_settings_for_target(target_name)
    user_selected_files = build_settings["ENABLE_USER_SELECTED_FILES"].to_s
    entitlements.delete("com.apple.security.files.user-selected.read-only")
    entitlements.delete("com.apple.security.files.user-selected.read-write")

    case user_selected_files
    when "readonly"
      entitlements["com.apple.security.files.user-selected.read-only"] = true
    when "readwrite"
      entitlements["com.apple.security.files.user-selected.read-write"] = true
    end
  end

  def sanitized_developer_id_entitlements_for(bundle_id, reference_entitlements_by_bundle_id: {})
    entitlements =
      if reference_entitlements_by_bundle_id.key?(bundle_id)
        deep_copy_hash(reference_entitlements_by_bundle_id.fetch(bundle_id))
      else
        source_path = developer_id_entitlements_sources[bundle_id]
        return nil if source_path.to_s.empty?

        fallback_entitlements = plist_hash(source_path)
        apply_xcode_managed_entitlements!(bundle_id, fallback_entitlements)
        fallback_entitlements
      end

    team_id = ensure_team_id!
    entitlements.delete("com.apple.security.get-task-allow")
    entitlements.delete("get-task-allow")
    entitlements["com.apple.application-identifier"] = "#{team_id}.#{bundle_id}"
    entitlements["com.apple.developer.team-identifier"] = team_id

    if entitlements.key?("com.apple.developer.aps-environment")
      entitlements["com.apple.developer.aps-environment"] = "production"
    end

    if entitlements["keychain-access-groups"].is_a?(Array)
      entitlements["keychain-access-groups"] =
        entitlements["keychain-access-groups"].map do |group|
          group.gsub(/\A[A-Z0-9]+\./, "#{team_id}.").gsub("$(AppIdentifierPrefix)", "#{team_id}.")
        end
    end

    entitlements
  end

  def resolved_entitlements_path_for(bundle_id, output_directory, reference_entitlements_by_bundle_id: {})
    entitlements = sanitized_developer_id_entitlements_for(
      bundle_id,
      reference_entitlements_by_bundle_id: reference_entitlements_by_bundle_id
    )
    return nil if entitlements.nil?

    FileUtils.mkdir_p(output_directory)
    entitlements_path = File.join(output_directory, "#{bundle_id}.entitlements")
    write_plist_hash(entitlements_path, entitlements)
    entitlements_path
  end

  def installed_provisioning_profile_path(uuid)
    profiles_dir = File.join(Dir.home, "Library", "MobileDevice", "Provisioning Profiles")
    matches = Dir.glob(File.join(profiles_dir, "#{uuid}.*"))
    UI.user_error!("Provisioning profile #{uuid} is not installed under #{profiles_dir}") if matches.empty?
    matches.first
  end

  def embed_provisioning_profile!(bundle_path, profile_path)
    destination =
      if File.directory?(File.join(bundle_path, "Contents"))
        File.join(bundle_path, "Contents", "embedded.provisionprofile")
      else
        File.join(bundle_path, "embedded.mobileprovision")
      end
    FileUtils.cp(profile_path, destination)
    destination
  end

  def nested_code_bundles(path)
    bundles = []

    Find.find(path) do |candidate|
      next if candidate == path
      next unless File.directory?(candidate)
      next unless %w[.app .appex .framework .xpc].include?(File.extname(candidate))

      bundles << candidate
      Find.prune
    end

    bundles.sort_by { |bundle_path| bundle_path.count(File::SEPARATOR) }.reverse
  end

  def loose_signable_files(path)
    files = []
    main_executable = bundle_executable_path(path)

    Find.find(path) do |candidate|
      if File.directory?(candidate)
        next if candidate == path

        if %w[.app .appex .framework .xpc].include?(File.extname(candidate))
          Find.prune
        end
        next
      end

      next unless File.file?(candidate)
      next if candidate == main_executable
      next unless File.extname(candidate) == ".dylib" || File.executable?(candidate)
      next unless candidate.include?("/Contents/Frameworks/") || candidate.include?("/Contents/Helpers/") || candidate.include?("/Contents/MacOS/") || candidate.include?("/Frameworks/")

      files << candidate
    end

    files.sort_by { |file_path| file_path.count(File::SEPARATOR) }.reverse
  end

  def sign_path!(path, identity:, keychain_path:, entitlements_path: nil, runtime: false)
    command = +"codesign --force --sign #{Shellwords.escape(identity)} " \
               "--keychain #{Shellwords.escape(keychain_path)} " \
               "--timestamp --generate-entitlement-der"
    command << " --options runtime" if runtime
    command << " --entitlements #{Shellwords.escape(entitlements_path)}" if entitlements_path
    command << " #{Shellwords.escape(path)}"
    sh(command)
  end

  def notarytool_auth_args(key_path:, key_id:, issuer_id:)
    [
      "--key #{Shellwords.escape(key_path)}",
      "--key-id #{Shellwords.escape(key_id)}",
      "--issuer #{Shellwords.escape(issuer_id)}"
    ].join(" ")
  end

  def summarize_notary_log(log_output)
    return nil if log_output.to_s.strip.empty?

    payload = JSON.parse(log_output)
    issues = payload["issues"]
    return nil unless issues.is_a?(Array) && !issues.empty?

    issues.first(5).map do |issue|
      path = issue["path"].to_s
      message = issue["message"].to_s
      severity = issue["severity"].to_s
      components = []
      components << severity unless severity.empty?
      components << path unless path.empty?
      components << message unless message.empty?
      components.join(": ")
    end.join("\n")
  rescue JSON::ParserError
    nil
  end

  def sign_bundle_recursively!(
    bundle_path,
    identity:,
    keychain_path:,
    entitlements_output_directory:,
    reference_entitlements_by_bundle_id: {}
  )
    nested_code_bundles(bundle_path).each do |nested_bundle_path|
      sign_bundle_recursively!(
        nested_bundle_path,
        identity: identity,
        keychain_path: keychain_path,
        entitlements_output_directory: entitlements_output_directory,
        reference_entitlements_by_bundle_id: reference_entitlements_by_bundle_id
      )
    end

    loose_signable_files(bundle_path).each do |file_path|
      runtime = File.executable?(file_path) && File.extname(file_path) != ".dylib"
      sign_path!(
        file_path,
        identity: identity,
        keychain_path: keychain_path,
        runtime: runtime
      )
    end

    bundle_id = bundle_identifier_for(bundle_path)
    unless bundle_id.nil?
      profile_uuid = developer_id_provisioning_profiles[bundle_id] rescue nil
      unless profile_uuid.to_s.empty?
        embed_provisioning_profile!(bundle_path, installed_provisioning_profile_path(profile_uuid))
      end
    end
    entitlements_path =
      if bundle_id.nil?
        nil
      else
        resolved_entitlements_path_for(
          bundle_id,
          entitlements_output_directory,
          reference_entitlements_by_bundle_id: reference_entitlements_by_bundle_id
        )
      end
    runtime = %w[.app .appex .xpc].include?(File.extname(bundle_path))

    sign_path!(
      bundle_path,
      identity: identity,
      keychain_path: keychain_path,
      entitlements_path: entitlements_path,
      runtime: runtime
    )
  end

  def env_value!(name)
    value = ENV[name].to_s.strip
    UI.user_error!("Missing #{name}") if value.empty?
    value
  end

  def ios_export_provisioning_profiles
    {
      "io.ethan.pushgo" => env_value!("APP_STORE_PROFILE_IOS_APP_UUID"),
      "io.ethan.pushgo.NotificationServiceExtension" => env_value!("APP_STORE_PROFILE_IOS_NSE_UUID"),
      "io.ethan.pushgo.watchkitapp" => env_value!("APP_STORE_PROFILE_WATCH_APP_UUID"),
      "io.ethan.pushgo.watchkitapp.NotificationServiceExtension" => env_value!("APP_STORE_PROFILE_WATCH_NSE_UUID")
    }
  end

  def macos_export_provisioning_profiles
    {
      "io.ethan.pushgo" => env_value!("APP_STORE_PROFILE_MACOS_APP_UUID"),
      "io.ethan.pushgo.NotificationServiceExtension" => env_value!("APP_STORE_PROFILE_MACOS_NSE_UUID")
    }
  end

  def write_export_options_plist(path, payload)
    write_plist_hash(path, payload)
  end

  def archive_ios_app!
    scheme = ENV.fetch("APP_SCHEME", "PushGo-iOS")
    project = resolve_from_repo(ENV.fetch("APP_PROJECT", "pushgo.xcodeproj"))
    output_directory = resolve_from_repo(ENV.fetch("BUILD_OUTPUT_DIR", "artifacts/release"))
    output_name = ENV.fetch("IPA_OUTPUT_NAME", "PushGo-iOS")
    export_method = "app-store-connect"
    team_id = ensure_team_id!
    archive_path = File.join(output_directory, "#{output_name}.xcarchive")
    export_path = File.join(output_directory, "#{output_name}-export")
    export_options_path = File.join(output_directory, "#{output_name}-ExportOptions.plist")
    ipa_path = File.join(output_directory, "#{output_name}.ipa")
    apple_distribution = apple_distribution_identity!
    archive_xcargs = local_signing_xcargs
    export_xcargs = export_archive_xcargs

    FileUtils.mkdir_p(output_directory)
    FileUtils.rm_rf([archive_path, export_path, ipa_path])

    sh(
      "xcodebuild -project #{Shellwords.escape(project)} " \
      "-scheme #{Shellwords.escape(scheme)} " \
      "-configuration Release " \
      "-destination 'generic/platform=iOS' " \
      "-archivePath #{Shellwords.escape(archive_path)} " \
      "archive #{archive_xcargs}"
    )

    write_export_options_plist(
      export_options_path,
      {
        "method" => export_method,
        "teamID" => team_id,
        "signingStyle" => "manual",
        "signingCertificate" => apple_distribution[:name],
        "provisioningProfiles" => ios_export_provisioning_profiles,
        "stripSwiftSymbols" => true,
        "manageAppVersionAndBuildNumber" => false
      }
    )

    sh(
      "xcodebuild -exportArchive " \
      "-archivePath #{Shellwords.escape(archive_path)} " \
      "-exportPath #{Shellwords.escape(export_path)} " \
      "-exportOptionsPlist #{Shellwords.escape(export_options_path)} " \
      "#{export_xcargs}"
    )

    generated_ipa = Dir.glob(File.join(export_path, "*.ipa")).first
    UI.user_error!("No .ipa found under #{export_path}") if generated_ipa.to_s.empty?
    verify_ios_distribution_signature!(generated_ipa)
    FileUtils.cp(generated_ipa, ipa_path)
    ipa_path
  end

  def archive_macos_app_store_pkg!
    project = resolve_from_repo(ENV.fetch("APP_PROJECT", "pushgo.xcodeproj"))
    scheme = ENV.fetch("APP_MACOS_SCHEME", "PushGo-macOS")
    team_id = ensure_team_id!
    output_directory = resolve_from_repo(ENV.fetch("BUILD_OUTPUT_DIR", "artifacts/release"))
    pkg_name = ENV.fetch("MACOS_PKG_OUTPUT_NAME", "PushGo-macOS")
    archive_path = File.join(output_directory, "#{pkg_name}.xcarchive")
    export_path = File.join(output_directory, "#{pkg_name}-export")
    export_options_path = File.join(output_directory, "#{pkg_name}-ExportOptions.plist")
    pkg_path = File.join(output_directory, "#{pkg_name}.pkg")
    apple_distribution = apple_distribution_identity!
    installer_distribution = mac_installer_distribution_identity!
    archive_xcargs = local_signing_xcargs
    export_xcargs = export_archive_xcargs

    FileUtils.mkdir_p(output_directory)
    FileUtils.rm_rf([archive_path, export_path, pkg_path])

    sh(
      "xcodebuild -project #{Shellwords.escape(project)} " \
      "-scheme #{Shellwords.escape(scheme)} " \
      "-configuration Release " \
      "-destination 'generic/platform=macOS' " \
      "-archivePath #{Shellwords.escape(archive_path)} " \
      "archive #{archive_xcargs}"
    )

    write_export_options_plist(
      export_options_path,
      {
        "method" => "app-store-connect",
        "teamID" => team_id,
        "signingStyle" => "manual",
        "signingCertificate" => apple_distribution[:name],
        "installerSigningCertificate" => installer_distribution[:name],
        "provisioningProfiles" => macos_export_provisioning_profiles,
        "stripSwiftSymbols" => true,
        "manageAppVersionAndBuildNumber" => false
      }
    )

    sh(
      "xcodebuild -exportArchive " \
      "-archivePath #{Shellwords.escape(archive_path)} " \
      "-exportPath #{Shellwords.escape(export_path)} " \
      "-exportOptionsPlist #{Shellwords.escape(export_options_path)} " \
      "#{export_xcargs}"
    )

    generated_pkg = Dir.glob(File.join(export_path, "*.pkg")).first
    UI.user_error!("No .pkg found under #{export_path}") if generated_pkg.to_s.empty?
    verify_macos_pkg_distribution_signature!(generated_pkg)
    FileUtils.cp(generated_pkg, pkg_path)
    pkg_path
  end

  def release_notes_payload
    notes = ENV["APP_STORE_RELEASE_NOTES"].to_s.strip
    return nil if notes.empty?

    {
      "en-US" => notes,
      "zh-Hans" => notes
    }
  end

  def build_release_dmg!
    project = resolve_from_repo(ENV.fetch("APP_PROJECT", "pushgo.xcodeproj"))
    scheme = ENV.fetch("APP_MACOS_DMG_SCHEME", ENV.fetch("APP_MACOS_SCHEME", "PushGo-macOS-DMG"))
    sparkle_xcconfig = resolve_from_repo(
      ENV.fetch("APP_MACOS_DMG_XCCONFIG", "config/PushGo-macOS-DMG-Sparkle.xcconfig")
    )
    output_directory = resolve_from_repo(ENV.fetch("BUILD_OUTPUT_DIR", "artifacts/release"))
    dmg_name = ENV.fetch("DMG_OUTPUT_NAME", "PushGo-macOS")
    archive_path = File.join(output_directory, "#{dmg_name}.xcarchive")
    export_path = File.join(output_directory, "#{dmg_name}-export")
    staging_dir = File.join(output_directory, "#{dmg_name}-staging")
    entitlements_dir = File.join(output_directory, "#{dmg_name}-entitlements")
    dmg_path = File.join(output_directory, "#{dmg_name}.dmg")
    keychain_path = developer_id_keychain_path!
    identity = developer_id_identity!
    display_version = resolved_display_version
    reference_derived_data_path = nil
    reference_entitlements_by_bundle_id = {}
    xcargs = local_signing_xcargs

    FileUtils.mkdir_p(output_directory)
    FileUtils.rm_rf([archive_path, export_path, staging_dir, entitlements_dir, dmg_path])
    UI.user_error!("Sparkle xcconfig not found: #{sparkle_xcconfig}") unless File.exist?(sparkle_xcconfig)

    begin
      reference_derived_data_path = Dir.mktmpdir("pushgo-macos-dmg-reference-")
      sh(
        "xcodebuild -project #{Shellwords.escape(project)} " \
        "-scheme #{Shellwords.escape(scheme)} " \
        "-xcconfig #{Shellwords.escape(sparkle_xcconfig)} " \
        "-configuration Release " \
        "-destination 'generic/platform=macOS' " \
        "-derivedDataPath #{Shellwords.escape(reference_derived_data_path)} " \
        "build " \
        "PUSHGO_DISPLAY_VERSION=#{Shellwords.escape(display_version)} " \
        "CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY='' DEVELOPMENT_TEAM=''"
      )
      reference_app_path = Dir.glob(File.join(reference_derived_data_path, "Build", "Products", "Release", "*.app")).first
      UI.user_error!("No reference .app found under #{reference_derived_data_path}") if reference_app_path.to_s.empty?
      reference_entitlements_by_bundle_id = extracted_entitlements_by_bundle_id(reference_app_path)

      sh(
        "xcodebuild -project #{Shellwords.escape(project)} " \
        "-scheme #{Shellwords.escape(scheme)} " \
        "-xcconfig #{Shellwords.escape(sparkle_xcconfig)} " \
        "-configuration Release " \
        "-destination 'generic/platform=macOS' " \
        "-archivePath #{Shellwords.escape(archive_path)} " \
        "archive " \
        "PUSHGO_DISPLAY_VERSION=#{Shellwords.escape(display_version)} " \
        "CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY='' DEVELOPMENT_TEAM=''"
      )

      archived_app_path = Dir.glob(File.join(archive_path, "Products", "Applications", "*.app")).first
      UI.user_error!("No archived .app found under #{archive_path}") if archived_app_path.to_s.empty?

      FileUtils.mkdir_p(export_path)
      app_path = File.join(export_path, File.basename(archived_app_path))
      sh("cp -R #{Shellwords.escape(archived_app_path)} #{Shellwords.escape(app_path)}")

      sign_bundle_recursively!(
        app_path,
        identity: identity,
        keychain_path: keychain_path,
        entitlements_output_directory: entitlements_dir,
        reference_entitlements_by_bundle_id: reference_entitlements_by_bundle_id
      )
      sh("codesign --verify --deep --strict --verbose=2 #{Shellwords.escape(app_path)}")
      verify_developer_id_app_signature!(app_path)

      FileUtils.mkdir_p(staging_dir)
      sh("cp -R #{Shellwords.escape(app_path)} #{Shellwords.escape(staging_dir)}")
      FileUtils.ln_s("/Applications", File.join(staging_dir, "Applications"), force: true)
      sh(
        "hdiutil create " \
        "-volname #{Shellwords.escape(dmg_name)} " \
        "-srcfolder #{Shellwords.escape(staging_dir)} " \
        "-ov -format UDZO #{Shellwords.escape(dmg_path)}"
      )
      sign_path!(
        dmg_path,
        identity: identity,
        keychain_path: keychain_path
      )
      sh("codesign --verify --verbose=2 #{Shellwords.escape(dmg_path)}")

      key_path = ENV["ASC_KEY_PATH"]
      key_id = ENV["ASC_KEY_ID"]
      issuer_id = ENV["ASC_ISSUER_ID"]
      UI.user_error!("Missing ASC_KEY_PATH for notarization") if key_path.to_s.empty?
      UI.user_error!("Missing ASC_KEY_ID for notarization") if key_id.to_s.empty?
      UI.user_error!("Missing ASC_ISSUER_ID for notarization") if issuer_id.to_s.empty?

      auth_args = notarytool_auth_args(key_path: key_path, key_id: key_id, issuer_id: issuer_id)
      notary_submit_path = File.join(output_directory, "#{dmg_name}-notarytool-submit.json")
      notary_log_path = File.join(output_directory, "#{dmg_name}-notarytool-log.json")
      notary_submit_output = with_transient_network_retry!("submit DMG to notarytool") do
        sh(
          "xcrun notarytool submit #{Shellwords.escape(dmg_path)} " \
          "#{auth_args} --wait --output-format json",
          log: false
        )
      end
      File.write(notary_submit_path, notary_submit_output)

      notary_submit_result = JSON.parse(notary_submit_output)
      notarization_status = notary_submit_result["status"].to_s
      notarization_id = notary_submit_result["id"].to_s

      unless notarization_status == "Accepted"
        notary_log_output = ""
        unless notarization_id.empty?
          begin
            notary_log_output = with_transient_network_retry!("fetch notarytool log") do
              sh(
                "xcrun notarytool log #{Shellwords.escape(notarization_id)} #{auth_args} --output-format json",
                log: false
              )
            end
            File.write(notary_log_path, notary_log_output)
          rescue StandardError => e
            File.write(notary_log_path, "Failed to fetch notary log: #{e.message}\n")
          end
        end

        notary_summary = summarize_notary_log(notary_log_output)
        details = []
        details << "submission_id=#{notarization_id}" unless notarization_id.empty?
        details << "submit_json=#{notary_submit_path}"
        details << "log_json=#{notary_log_path}" if File.exist?(notary_log_path)
        detail_suffix = details.empty? ? "" : " (#{details.join(', ')})"

        message = "DMG notarization failed with status #{notarization_status}#{detail_suffix}."
        message = "#{message}\n#{notary_summary}" unless notary_summary.to_s.empty?
        UI.user_error!(message)
      end

      sh("xcrun stapler staple #{Shellwords.escape(dmg_path)}")
      sh("xcrun stapler validate #{Shellwords.escape(dmg_path)}")
      sh("spctl --assess --type open --context context:primary-signature -vv #{Shellwords.escape(dmg_path)}")

      dmg_path
    ensure
      FileUtils.rm_rf(reference_derived_data_path) unless reference_derived_data_path.to_s.empty?
    end
  end

  def upload_beta_builds!
    api_key = app_store_api_key!
    ios_ipa_path = archive_ios_app!
    macos_pkg_path = archive_macos_app_store_pkg!
    changelog = ENV["TESTFLIGHT_CHANGELOG"].to_s.strip
    groups = ENV.fetch("TESTFLIGHT_EXTERNAL_GROUPS", "").split(",").map(&:strip).reject(&:empty?)
    UI.user_error!("Missing TESTFLIGHT_EXTERNAL_GROUPS for beta auto-submit") if groups.empty?

    with_transient_asc_retry!("upload iOS build to TestFlight") do
      upload_to_testflight(
        api_key: api_key,
        ipa: ios_ipa_path,
        changelog: changelog.empty? ? nil : changelog,
        groups: groups,
        distribute_external: true,
        submit_beta_review: true,
        skip_waiting_for_build_processing: false
      )
    end
    with_transient_asc_retry!("upload macOS build to TestFlight") do
      upload_to_testflight(
        api_key: api_key,
        pkg: macos_pkg_path,
        changelog: changelog.empty? ? nil : changelog,
        groups: groups,
        distribute_external: true,
        submit_beta_review: true,
        skip_waiting_for_build_processing: false
      )
    end
  end

  def upload_release_builds!
    api_key = app_store_api_key!
    ios_ipa_path = archive_ios_app!
    macos_pkg_path = archive_macos_app_store_pkg!
    release_notes = release_notes_payload

    with_transient_asc_retry!("upload iOS build to App Store Connect") do
      upload_to_app_store(
        api_key: api_key,
        ipa: ios_ipa_path,
        skip_metadata: false,
        skip_screenshots: true,
        release_notes: release_notes,
        submit_for_review: ENV.fetch("APP_STORE_SUBMIT_FOR_REVIEW", "false") == "true",
        automatic_release: ENV.fetch("APP_STORE_AUTOMATIC_RELEASE", "false") == "true",
        run_precheck_before_submit: false,
        force: true
      )
    end
    with_transient_asc_retry!("upload macOS build to App Store Connect") do
      upload_to_app_store(
        api_key: api_key,
        pkg: macos_pkg_path,
        skip_metadata: false,
        skip_screenshots: true,
        release_notes: release_notes,
        submit_for_review: ENV.fetch("APP_STORE_SUBMIT_FOR_REVIEW", "false") == "true",
        automatic_release: ENV.fetch("APP_STORE_AUTOMATIC_RELEASE", "false") == "true",
        run_precheck_before_submit: false,
        force: true
      )
    end
  end

  def network_retry_attempts
    raw = ENV.fetch("NETWORK_MAX_ATTEMPTS", ENV.fetch("ASC_UPLOAD_MAX_ATTEMPTS", "3")).to_i
    raw > 0 ? raw : 1
  end

  def network_retry_base_seconds
    raw = ENV.fetch("NETWORK_RETRY_BASE_SECONDS", ENV.fetch("ASC_UPLOAD_RETRY_BASE_SECONDS", "20")).to_i
    raw > 0 ? raw : 20
  end

  def transient_network_error?(error)
    message = error.to_s
    return false if message.empty?

    patterns = [
      /NSURLErrorDomain\s+Code=-1009/i,
      /NSURLErrorDomain\s+Code=-1001/i,
      /timed?\s*out/i,
      /could not connect/i,
      /connection (?:was )?lost/i,
      /connection reset/i,
      /network route/i,
      /network is unreachable/i,
      /broken pipe/i,
      /could not resolve host/i,
      /GET UPLOAD STATE .* did not receive a response/i,
      /server returned an invalid response/i,
      /temporar(?:y|ily) unavailable/i,
      /remote end hung up unexpectedly/i,
      /kex_exchange_identification/i,
      /TLS/i,
      /SSL/i,
      /HTTP(?:\/\d\.\d)?\s+50[0-9]\b/i,
      /\b502\b|\b503\b|\b504\b/
    ]

    patterns.any? { |pattern| message.match?(pattern) }
  end

  def with_transient_network_retry!(operation_name)
    attempts = network_retry_attempts
    base_sleep = network_retry_base_seconds
    current = 0

    begin
      current += 1
      return yield
    rescue StandardError => e
      unless transient_network_error?(e) && current < attempts
        raise
      end

      sleep_seconds = base_sleep * (2**(current - 1))
      UI.important(
        "#{operation_name} failed with transient network error " \
        "(attempt #{current}/#{attempts}): #{e.message}\nRetrying in #{sleep_seconds}s..."
      )
      sleep(sleep_seconds)
      retry
    end
  end

  def with_transient_asc_retry!(operation_name, &block)
    with_transient_network_retry!(operation_name, &block)
  end

  desc "Archive and upload build to TestFlight"
  lane :beta_upload do
    upload_beta_builds!
  end

  desc "Archive and upload build to App Store"
  lane :release_upload do
    upload_release_builds!
  end

  desc "Build and notarize DMG for beta tags"
  lane :beta_dmg do
    build_release_dmg!
  end

  desc "Build and notarize DMG for release tags"
  lane :release_dmg do
    build_release_dmg!
  end

  desc "Archive, upload, and notarize beta artifacts"
  lane :beta do
    upload_beta_builds!
    build_release_dmg!
  end

  desc "Archive, upload, and notarize release artifacts"
  lane :release do
    upload_release_builds!
    build_release_dmg!
  end
end
