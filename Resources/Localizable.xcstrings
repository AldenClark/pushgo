    "watch_companion_not_available": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Apple-Watch-Begleit-App ist nicht verfügbar. Installiere die Watch-App und kopple die Uhr, bevor du den Standalone-Modus aktivierst."
          }
        },
        "en": {
