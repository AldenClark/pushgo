          }
        }
      }
    },
    "watch_standalone_mode_still_waiting_message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten weiterhin auf die Bestätigung des Standalone-Modus durch Apple Watch. PushGo versucht es im Hintergrund weiter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Still waiting for Apple Watch to confirm standalone mode. PushGo will keep trying in the background."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún esperando que Apple Watch confirme el modo independiente. PushGo seguirá intentándolo en segundo plano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toujours en attente de la confirmation du mode autonome par Apple Watch. PushGo continuera de réessayer en arrière-plan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watchの単独モード確認を待機中です。PushGoはバックグラウンドで再試行を続けます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch의 독립 모드 확인을 기다리는 중입니다. PushGo가 백그라운드에서 계속 재시도합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仍在等待 Apple Watch 确认独立模式。PushGo 会在后台持续重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "仍在等待 Apple Watch 確認獨立模式。PushGo 會在背景持續重試。"
          }
        }
      }
    },
    "watch_standalone_mode_switched_message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch hat in den Standalone-Modus gewechselt und bereitet den Direktempfang vor. Das iPhone synchronisiert weiter, bis die Uhr bereit ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch has switched to standalone mode and is preparing direct reception. iPhone will keep syncing messages until the watch is ready."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch cambió al modo independiente y está preparando la recepción directa. El iPhone seguirá sincronizando mensajes hasta que el reloj esté listo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch est passée en mode autonome et prépare la réception directe. L’iPhone continue de synchroniser les messages jusqu’à ce que la montre soit prête."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watchは単独モードに切り替わり、直接受信の準備中です。準備が完了するまでiPhoneは同期を継続します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch가 독립 모드로 전환되어 직접 수신을 준비 중입니다. 준비가 완료될 때까지 iPhone이 동기화를 계속합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch 已切换到独立模式，正在准备直接接收。手表就绪前 iPhone 会继续同步消息。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch 已切換到獨立模式，正在準備直接接收。手錶就緒前 iPhone 會持續同步訊息。"
          }
        }
      }
    },
