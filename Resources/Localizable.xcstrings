    "server_management_gateway_switch_warning": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach dem Wechsel des Gateways werden vorhandene Kanalabos in dieser App entfernt. Bitte richte die Kanäle im neuen Gateway manuell erneut ein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After switching gateway, existing channel subscriptions in this app will be cleared. Please recreate channels on the new gateway manually."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al cambiar de gateway, se borrarán las suscripciones de canales existentes en esta app. Vuelve a crear los canales manualmente en el nuevo gateway."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après le changement de passerelle, les abonnements de canal existants dans cette app seront supprimés. Recréez manuellement les canaux sur la nouvelle passerelle."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "After switching gateway, existing channel subscriptions in this app will be cleared. Please recreate channels on the new gateway manually."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "After switching gateway, existing channel subscriptions in this app will be cleared. Please recreate channels on the new gateway manually."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换网关后，当前 App 内已有频道订阅会被清空。请在新网关中手动重新创建频道。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換網關後，當前 App 內已有頻道訂閱會被清空。請在新網關中手動重新建立頻道。"
          }
        }
