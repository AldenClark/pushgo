    "auto_cleanup_manual_suggestion" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Messages are getting slow. You can manually clean up older messages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "表示が遅くなっています。古いメッセージを手動で整理できます。"
