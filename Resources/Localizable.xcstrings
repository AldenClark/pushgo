          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los mensajes van más lentos. Puedes limpiar manualmente los mensajes antiguos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les messages deviennent lents. Vous pouvez nettoyer manuellement les anciens messages."
          }
        }
      }
    },
    "auto_cleanup_messages" : {
