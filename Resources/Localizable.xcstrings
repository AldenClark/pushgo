            "value" : "Standalone-Modus ist aktiv. Apple Watch kann bei Netzwerkzugang Nachrichten unabhängig empfangen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standalone mode is active. Apple Watch can receive messages independently when it has network access."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El modo independiente está activo. Apple Watch puede recibir mensajes de forma autónoma cuando tiene red."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
