    "Waiting for Apple Watch to accept standalone mode. This request will time out automatically if the watch does not respond." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warten, bis Apple Watch den Standalone-Modus akzeptiert. Diese Anfrage läuft automatisch ab, wenn die Uhr nicht antwortet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Waiting for Apple Watch to accept standalone mode. This request will time out automatically if the watch does not respond."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperando a que Apple Watch acepte el modo independiente. Esta solicitud vencerá automáticamente si el reloj no responde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En attente de l’acceptation du mode autonome par Apple Watch. Cette requête expirera automatiquement si la montre ne répond pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watchが単独モード要求を受け入れるのを待機中です。応答がない場合、この要求は自動でタイムアウトします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch가 독립 모드 요청을 수락할 때까지 기다리는 중입니다. 응답이 없으면 이 요청은 자동으로 시간 초과됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "正在等待 Apple Watch 接受独立模式。若手表无响应，此请求会自动超时。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "正在等待 Apple Watch 接受獨立模式。若手錶無回應，此請求會自動逾時。"
          }
        }
      }
    },
