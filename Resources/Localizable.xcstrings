    "select_sound_folder_permission_prompt": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle den Ordner ~/Library/Sounds aus, damit PushGo eigene Benachrichtigungstöne speichern kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select the ~/Library/Sounds folder so PushGo can save custom notification sounds."
