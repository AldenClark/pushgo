    "A stable object view: profile, standardized attributes, and linked event streams." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A stable object view: profile, standardized attributes, and linked event streams."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プロフィール、標準化属性、関連イベントストリームを統合した安定的なオブジェクト表示。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "프로필, 표준화 속성, 연관 이벤트 스트림을 묶은 안정적인 오브젝트 뷰."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "稳定的对象视图：聚合档案、标准化属性与关联事件流。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "穩定的物件視圖：聚合檔案、標準化屬性與關聯事件流。"
          }
        }
      }
