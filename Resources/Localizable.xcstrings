    "sidebar_launch_at_login_reminder_detail" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PushGo cannot receive messages while it is not running. Enable launch at login to keep message delivery available after your Mac starts."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PushGo が起動していない間はメッセージを受信できません。Mac の起動後も受信できるよう、ログイン時の起動を有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PushGo가 실행 중이 아니면 메시지를 받을 수 없습니다. Mac 시작 후에도 계속 수신하려면 로그인 시 실행을 켜세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PushGo 未启动时无法接收消息。建议开启开机自启，确保 Mac 启动后仍可持续接收消息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PushGo 未啟動時無法接收訊息。建議開啟開機自啟，確保 Mac 啟動後仍可持續接收訊息。"
          }
