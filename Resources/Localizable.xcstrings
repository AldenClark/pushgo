    "Apple Watch has switched to standalone mode and is preparing direct reception. iPhone will keep syncing messages until the watch is ready." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch has switched to standalone mode and is preparing direct reception. iPhone will keep syncing messages until the watch is ready."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watchは単独モードに切り替わり、直接受信の準備中です。準備が完了するまでiPhoneは同期を継続します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch가 독립 모드로 전환되어 직접 수신을 준비 중입니다. 준비가 완료될 때까지 iPhone이 동기화를 계속합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch 已切换到独立模式，正在准备直接接收。手表就绪前 iPhone 会继续同步消息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch 已切換到獨立模式，正在準備直接接收。手錶就緒前 iPhone 會持續同步訊息。"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch hat in den Standalone-Modus gewechselt und bereitet den Direktempfang vor. Das iPhone synchronisiert weiter, bis die Uhr bereit ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch cambió al modo independiente y está preparando la recepción directa. El iPhone seguirá sincronizando mensajes hasta que el reloj esté listo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch est passée en mode autonome et prépare la réception directe. L’iPhone continue de synchroniser les messages jusqu’à ce que la montre soit prête."
          }
        }
      }
    },
