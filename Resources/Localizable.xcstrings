    "Mirror mode follows your iPhone. iPhone continues syncing messages to Apple Watch." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mirror mode follows your iPhone. iPhone continues syncing messages to Apple Watch."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ミラーモードはiPhoneに追従します。iPhoneはApple Watchへのメッセージ同期を継続します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "미러 모드는 iPhone 설정을 따릅니다. iPhone이 Apple Watch로 메시지 동기화를 계속합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "镜像模式将跟随 iPhone。iPhone 会继续向 Apple Watch 同步消息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "鏡像模式將跟隨 iPhone。iPhone 會持續向 Apple Watch 同步訊息。"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Spiegelmodus folgt deinem iPhone. Das iPhone synchronisiert weiterhin Nachrichten mit der Apple Watch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El modo espejo sigue al iPhone. El iPhone sigue sincronizando mensajes con Apple Watch."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le mode miroir suit votre iPhone. L’iPhone continue de synchroniser les messages avec Apple Watch."
          }
        }
      }
    },
