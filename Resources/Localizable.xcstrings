    "sound_folder_permission_explanation": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PushGo benötigt Lese- und Schreibzugriff auf ~/Library/Sounds, bevor eigene Benachrichtigungstöne gespeichert werden können."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PushGo needs read and write access to ~/Library/Sounds before custom notification sounds can be saved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PushGo necesita acceso de lectura y escritura a ~/Library/Sounds para guardar sonidos de notificación personalizados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PushGo a besoin d’un accès en lecture et écriture à ~/Library/Sounds pour enregistrer les sons de notification personnalisés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カスタム通知サウンドを保存するには、PushGo に ~/Library/Sounds の読み書き権限が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용자 지정 알림 사운드를 저장하려면 PushGo에 ~/Library/Sounds 읽기 및 쓰기 권한이 필요합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存自定义通知铃声前，PushGo 需要 ~/Library/Sounds 的读写权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "儲存自訂通知鈴聲前，PushGo 需要 ~/Library/Sounds 的讀寫權限。"
          }
        }
      }
    },
