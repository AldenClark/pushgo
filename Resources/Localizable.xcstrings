    "enable_beta_updates_detail": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach dem Aktivieren empfaengst du Updates aus sparkle:channel=beta; ausserdem wird sofort eine Hintergrundpruefung gestartet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After enabling this option, you will receive updates from sparkle:channel=beta and the app will immediately run one background check."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al activarlo, recibiras actualizaciones de sparkle:channel=beta y la app hara una comprobacion en segundo plano de inmediato."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois active, vous recevrez les mises a jour de sparkle:channel=beta et l'app lancera aussitot une verification en arriere-plan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると sparkle:channel=beta からの更新を受け取り、すぐにバックグラウンドで一度更新確認を行います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성화하면 sparkle:channel=beta 업데이트를 받게 되며, 즉시 백그라운드에서 한 번 확인합니다."
