    "auto_cleanup_messages" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auto-clean read messages"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
