            "value" : "必要項目だけ入れてサイズを抑え、鍵は安全にローテーションし、運用前にサンプルで試験する。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필요한 항목만 담아 크기를 줄이고, 키는 안전하게 로테이션하며, 배포 전 샘플로 테스트하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持密文精简，谨慎轮换密钥，生产前用样例充分测试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持密文精簡，謹慎輪換密鑰，上線前用樣例充分測試。"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Payload klein halten, Schlüssel sicher rotieren und vor Produktion mit Beispieldaten testen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén el payload pequeño, rota las claves de forma segura y prueba con datos de ejemplo antes de producción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez un payload léger, faites une rotation sûre des clés et testez avec des données d’exemple avant la production."
          }
        }
      }
    },
