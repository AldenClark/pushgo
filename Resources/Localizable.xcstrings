    "If your watch can access the network independently, switch from mirror mode to standalone reception." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If your watch can access the network independently, switch from mirror mode to standalone reception."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watch が単独でネット接続できる場合は、ミラーモードから単独受信に切り替えられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watch가 단독으로 네트워크에 연결될 수 있다면 미러 모드에서 독립 수신 모드로 전환할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你的手表可以独立联网，可从镜像模式切换为独立接收。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果手錶可獨立連網，可由鏡像模式切換為獨立接收。"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn deine Uhr eigenständig auf das Netzwerk zugreifen kann, wechsle vom Spiegelmodus in den Standalone-Empfang."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tu reloj puede acceder a la red por sí solo, cambia del modo espejo a recepción independiente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si votre montre peut accéder au réseau de façon autonome, passez du mode miroir à la réception autonome."
          }
        }
      }
    },
