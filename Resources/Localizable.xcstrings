    "ciphertext_code_sample" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{\n  \"title\": \"Encrypted title\",\n  \"body\": \"Encrypted body\",\n  \"icon\": \"https://example.com/icon.png\",\n  \"image\": \"https://example.com/image.png\"\n}\n\n// Encrypt JSON with AES-GCM using your shared key and IV\n// ciphertext = Base64(cipher||tag||iv); send only this ciphertext field (IV is embedded)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{\n  \"title\": \"暗号化タイトル\",\n  \"body\": \"暗号化本文\",\n  \"icon\": \"https://example.com/icon.png\",\n  \"image\": \"https://example.com/image.png\"\n}\n\n// 共有鍵 + IV を使い AES-GCM で上記 JSON を暗号化\n// ciphertext = Base64(cipher||tag||iv) とし、IV を含んだ ciphertext フィールドだけ送信。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{\n  \"title\": \"암호화된 제목\",\n  \"body\": \"암호화된 본문\",\n  \"icon\": \"https://example.com/icon.png\",\n  \"image\": \"https://example.com/image.png\"\n}\n\n// 공유 키 + IV로 위 JSON을 AES-GCM으로 암호화\n// ciphertext = Base64(cipher||tag||iv) 로 만들고, IV가 포함된 ciphertext 필드만 보냅니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{\n  \"title\": \"加密标题\",\n  \"body\": \"加密正文\",\n  \"icon\": \"https://example.com/icon.png\",\n  \"image\": \"https://example.com/image.png\"\n}\n\n// 使用共享密钥 + IV 通过 AES-GCM 加密上述 JSON\n// ciphertext = Base64(cipher||tag||iv)，仅发送 ciphertext 字段（已包含 IV）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{\n  \"title\": \"加密標題\",\n  \"body\": \"加密正文\",\n  \"icon\": \"https://example.com/icon.png\",\n  \"image\": \"https://example.com/image.png\"\n}\n\n// 使用共享密鑰 + IV 以 AES-GCM 加密上述 JSON\n// ciphertext = Base64(cipher||tag||iv)，僅傳送 ciphertext 欄位（已含 IV）。"
          }
        }
      }
    },
