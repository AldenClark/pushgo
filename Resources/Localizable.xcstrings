    "watch_standalone_confirm_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Light mode mirrors notifications from iPhone. Standalone mode receives messages directly on Apple Watch. In standalone mode, your watch can receive messages independently when away from iPhone as long as it has network access. Each switch may take some time to sync data."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "轻量模式会完全镜像 iOS 通知。独立模式下 Apple Watch 会完全独立收取消息；离开手机时，只要手表联网也能独立接收。每次切换模式都可能需要一些时间来同步数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "輕量模式會完整鏡像 iOS 通知。獨立模式下 Apple Watch 會完全獨立收取訊息；離開手機時，只要手錶連網也能獨立接收。每次切換模式都可能需要一些時間同步資料。"
          }
        }
      }
    },
